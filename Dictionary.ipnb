,"user_tz":-330,"elapsed":21,"user":{"displayName":"Rakshitha R","userId":"08346891342560843717"}},"outputId":"0ad87647-c8f0-4a95-f214-bdeeabffd14a"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Dictionary-  {1: 8.9, 2: 5.6, 4: 6.7, 7: 9.1, 8: 5.3}\n","\n","keys -  [1, 2, 4, 7, 8]\n","\n","values -  [8.9, 5.6, 6.7, 9.1, 5.3]\n","\n","items -  [(1, 8.9), (2, 5.6), (4, 6.7), (7, 9.1), (8, 5.3)]\n"]}]},{"cell_type":"code","source":["#To find minimum values of keys-Method 1\n","CGPA={1:8.9,2:5.6,4:6.7,7:9.1,8:5.3}\n","print(\"Dictionary- \",CGPA)\n","\n","keylist=list(CGPA.keys())\n","vallist=list(CGPA.values())\n","minval=min(CGPA.values())\n","\n","print(\"\\nMin Value=\",minval,\" and its key-\",keylist[vallist.index(minval)])"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"RU-PqDSF12sK","executionInfo":{"status":"ok","timestamp":1767930776402,"user_tz":-330,"elapsed":46,"user":{"displayName":"Rakshitha R","userId":"08346891342560843717"}},"outputId":"91533726-49e8-467c-ce66-fbbdc551345a"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Dictionary-  {1: 8.9, 2: 5.6, 4: 6.7, 7: 9.1, 8: 5.3}\n","\n","Min Value= 5.3  and its key- 8\n"]}]},{"cell_type":"code","source":["#To find maximum values of keys-Method 1\n","CGPA={1:8.9,2:5.6,4:6.7,7:9.1,8:5.3}\n","print(\"Dictionary- \",CGPA)\n","\n","keylist=list(CGPA.keys())\n","vallist=list(CGPA.values())\n","maxval=max(CGPA.values())\n","\n","print(\"\\nMax Value=\",maxval,\" and its key-\",keylist[vallist.index(maxval)])"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"zq7yY6M_4hnq","executionInfo":{"status":"ok","timestamp":1767930913267,"user_tz":-330,"elapsed":15,"user":{"displayName":"Rakshitha R","userId":"08346891342560843717"}},"outputId":"181a018b-0331-4afd-f952-6f53ab4ef1cb"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Dictionary-  {1: 8.9, 2: 5.6, 4: 6.7, 7: 9.1, 8: 5.3}\n","\n","Max Value= 9.1  and its key- 7\n"]}]},{"cell_type":"code","source":["#To find minimum values of keys-Method 2\n","CGPA={1:8.9,2:5.6,4:6.7,7:9.1,8:5.3}\n","print(\"Dictionary- \",CGPA)\n","\n","print(\"\\nKey having minimum value-\",min(CGPA,key=CGPA.get))\n","print(\"\\nKey having maximum value-\",max(CGPA,key=CGPA.get))"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"v5bzICtM5HcZ","executionInfo":{"status":"ok","timestamp":1767931164667,"user_tz":-330,"elapsed":18,"user":{"displayName":"Rakshitha R","userId":"08346891342560843717"}},"outputId":"9bccc256-e713-4c85-cb71-34f17c9ff439"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Dictionary-  {1: 8.9, 2: 5.6, 4: 6.7, 7: 9.1, 8: 5.3}\n","\n","Key having minimum value- 8\n","\n","Key having maximum value- 7\n"]}]},{"cell_type":"code","source":["#to search an element\n","CGPA={1:8.9,2:5.6,4:6.7,7:9.1,8:5.3}\n","print(\"Dictionary- \",CGPA)\n","\n","print(\"\\nIs key 2 present-\",2 in CGPA.keys())\n","print(\"\\nIs key 9 present-\",9 in CGPA.keys())"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Psz-xOX06LbZ","executionInfo":{"status":"ok","timestamp":1767931491518,"user_tz":-330,"elapsed":44,"user":{"displayName":"Rakshitha R","userId":"08346891342560843717"}},"outputId":"81e94b0e-4d06-49f5-ab12-5797274d24ba"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Dictionary-  {1: 8.9, 2: 5.6, 4: 6.7, 7: 9.1, 8: 5.3}\n","\n","Is key 2 present- True\n","\n","Is key 9 present- False\n"]}]},{"cell_type":"code","source":[" #To merge Dictionary\n","CGPA1={1:8.9,2:5.6,4:9.7}\n","CGPA2={4:6.7,7:9.1,8:5.3}\n","\n","print(\"CGPA1=\",CGPA1)\n","print(\"CGPA2=\",CGPA2)\n","\n","CGPA2.update(CGPA1)\n","print(\"\\nCGPA1 after update\",CGPA1)\n","print(\"\\nCGPA2 after update\",CGPA2)\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"YRhjDXTY7JYB","executionInfo":{"status":"ok","timestamp":1767932114936,"user_tz":-330,"elapsed":7,"user":{"displayName":"Rakshitha R","userId":"08346891342560843717"}},"outputId":"1f6a5ec0-2cb6-4a31-8de6-bcd836cca55c"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["CGPA1= {1: 8.9, 2: 5.6, 4: 9.7}\n","CGPA2= {4: 6.7, 7: 9.1, 8: 5.3}\n","\n","CGPA1 after update {1: 8.9, 2: 5.6, 4: 9.7}\n","\n","CGPA2 after update {4: 9.7, 7: 9.1, 8: 5.3, 1: 8.9, 2: 5.6}\n"]}]},{"cell_type":"code","source":["#ASSIGNMENT"],"metadata":{"id":"ABp_unZg9zbY"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["#Q1.Create a dictionary named cars\n","#keys-brand,model,year\n","#values-Ford,Mustang,1964\n","\n","Cars={'Brand':'Ford','Model':'Mustang','Year':1964}\n","\n","#Q2. print dictionary elements\n","\n","print(\"Dictionary - \",Cars)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"jnahPNG8-mY4","executionInfo":{"status":"ok","timestamp":1767932562939,"user_tz":-330,"elapsed":7,"user":{"displayName":"Rakshitha R","userId":"08346891342560843717"}},"outputId":"6cbecf64-35b6-4493-c31c-3ab003b6a4c2"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Dictionary -  {'Brand': 'Ford', 'Model': 'Mustang', 'Year': 1964}\n"]}]},{"cell_type":"code","source":["#Q3. Add one more element color:red\n","\n","Cars['Color']='Red'\n","print(\"\\nNew Dictionary - \",Cars)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"gM2TSv2l_gzY","executionInfo":{"status":"ok","timestamp":1767932744831,"user_tz":-330,"elapsed":13,"user":{"displayName":"Rakshitha R","userId":"08346891342560843717"}},"outputId":"5619d287-4929-43bc-c592-18a354e2535b"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","New Dictionary -  {'Brand': 'Ford', 'Model': 'Mustang', 'Year': 1964, 'Color': 'Red'}\n"]}]},{"cell_type":"code","source":["#Q4.Print keys,values,items\n","\n","print(\"Dictionary=\",Cars)\n","print(\"\\nKeys= \",Cars.keys())\n","print(\"\\nValues= \",Cars.values())\n","print(\"\\nItems= \",Cars.items())"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"twUlxjIW_84w","executionInfo":{"status":"ok","timestamp":1767932901436,"user_tz":-330,"elapsed":20,"user":{"displayName":"Rakshitha R","userId":"08346891342560843717"}},"outputId":"505640f4-b9c8-4f1a-c0d4-1b955cdef803"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Dictionary= {'Brand': 'Ford', 'Model': 'Mustang', 'Year': 1964, 'Color': 'Red'}\n","\n","Keys=  dict_keys(['Brand', 'Model', 'Year', 'Color'])\n","\n","Values=  dict_values(['Ford', 'Mustang', 1964, 'Red'])\n","\n","Items=  dict_items([('Brand', 'Ford'), ('Model', 'Mustang'), ('Year', 1964), ('Color', 'Red')])\n"]}]},{"cell_type":"code","source":["#Q5.Check whether model is present in cars dictionary\n","\n","print(\"Is key Model present in cars dictionary - \",'Model' in Cars.keys())"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"jdDdcGQBAvr4","executionInfo":{"status":"ok","timestamp":1767933018469,"user_tz":-330,"elapsed":15,"user":{"displayName":"Rakshitha R","userId":"08346891342560843717"}},"outputId":"ec534a07-4cd0-4ed4-fcfa-e03588d0020d"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Is key Model present in cars dictionary -  True\n"]}]},{"cell_type":"code","source":["#Q. Create a dictionary from 2 list\n","#key=movie,hero,release year\n","#values=Kantara,Rishab,2022\n","\n","keyl=['movie','hero','release_year']\n","vall=['Kantara','Rishab',2022]\n","mdict={}\n","for i in range(len(keyl)):\n","    mdict[keyl[i]]=vall[i]\n","print(mdict)\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"FNn6feXYBMhm","executionInfo":{"status":"ok","timestamp":1767934480110,"user_tz":-330,"elapsed":15,"user":{"displayName":"Rakshitha R","userId":"08346891342560843717"}},"outputId":"90e3a15b-ee4f-4428-f5be-757c4c770291"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["{'movie': 'Kantara', 'hero': 'Rishab', 'release_year': 2022}\n"]}]},{"cell_type":"code","source":["#Copying from one dictionary to another\n","#Method1 using '=' operator\n","\n","dict1={'Name':'John',10:[2,4,3]}\n","dict2=dict1\n","print('dict1=',dict1)\n","print('dict2=',dict2)\n","print()\n","print(\"After doing change \")\n","print()\n","dict1.popitem()\n","print('dict1=',dict1)\n","print('dict2=',dict2)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"kWmEONltE7yA","executionInfo":{"status":"ok","timestamp":1767935314303,"user_tz":-330,"elapsed":19,"user":{"displayName":"Rakshitha R","userId":"08346891342560843717"}},"outputId":"e3b171bc-4874-4ccc-c154-46fe175bfb9a"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["dict1= {'Name': 'John', 10: [2, 4, 3]}\n","dict2= {'Name': 'John', 10: [2, 4, 3]}\n","\n","After doing change \n","\n","dict1= {'Name': 'John'}\n","dict2= {'Name': 'John'}\n"]}]},{"cell_type":"code","source":["#Copying from one dictionary to another\n","#Method2 using 'copy'\n","\n","dict1={'Name':'John',10:[2,4,3]}\n","dict2=dict1.copy()\n","print('dict1=',dict1)\n","print(\"dict2=\",dict2)\n","print()\n","print(\"After doing change \")\n","print()\n","dict1.popitem()\n","print('dict1=',dict1)\n","print('dict2=',dict2)\n","print(\"\\nChange in dict1 will not reflect in dict2\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"_Ld2yuvrItOW","executionInfo":{"status":"ok","timestamp":1767935253520,"user_tz":-330,"elapsed":17,"user":{"displayName":"Rakshitha R","userId":"08346891342560843717"}},"outputId":"8fe838e8-35b8-4b7b-acf0-7ced7ef83a47"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["dict1= {'Name': 'John', 10: [2, 4, 3]}\n","dict2= {'Name': 'John', 10: [2, 4, 3]}\n","\n","After doing change \n","\n","dict1= {'Name': 'John'}\n","dict2= {'Name': 'John', 10: [2, 4, 3]}\n","\n","Change in dict1 will not reflect in dict2\n"]}]},{"cell_type":"code","source":[],"metadata":{"id":"_cD-WVwhJMsv","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1768188721089,"user_tz":-330,"elapsed":17,"user":{"displayName":"Rakshitha R","userId":"08346891342560843717"}},"outputId":"a729495f-76a1-4fb7-fc9f-7f7e4d7bdfac"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["n of  2\n","n of  4\n","n of  6\n"]}]},{"cell_type":"code","source":[],"metadata":{"id":"sCfl9wYOQnaJ"},"execution_count":null,"outputs":[]}]}