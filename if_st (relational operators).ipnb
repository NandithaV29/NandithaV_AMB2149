st all the pesticides whose effectiveness is above 80%\n","\n","print(\"Pesticides whose effectiveness is above 80% are: \")\n","for i in range(len(effectiveness)):\n","    if(effectiveness[i]>80):\n","        print(pesticide[i])"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"vovw_U_OehkN","executionInfo":{"status":"ok","timestamp":1767152562612,"user_tz":-330,"elapsed":7,"user":{"displayName":"Rakshitha R","userId":"08346891342560843717"}},"outputId":"d242312f-efa9-423a-e3f0-2deeaa374368"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Pesticides whose effectiveness is above 80% are: \n","cloropyriphos\n","imidacloprid\n","spinosad\n"]}]},{"cell_type":"code","source":["#count all the pesticides whose effectiveness is below 80%\n","\n","print(\"The number pesticides whose effectiveness is below 80% :\")\n","for i in range(len(effectiveness)):\n","    if(effectiveness[i]<80):\n","        print(pesticides[i])\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"YwZvw3FShpXB","executionInfo":{"status":"ok","timestamp":1767153846359,"user_tz":-330,"elapsed":50,"user":{"displayName":"Rakshitha R","userId":"08346891342560843717"}},"outputId":"2a9febe0-e484-44f0-cb36-0a340360507c"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["The number pesticides whose effectiveness is below 80% :\n","Neemoil\n","Malathion\n"]}]},{"cell_type":"code","source":["#Increase the effectiveness of all pesticides by 5% and display the updated list\n","pesticides=['Neemoil','Cloropyriphos','Malathion','Imidacloprid','Spinosad']\n","effectiveness=[75,85,70,90,88]\n","e=[]\n","for i in effectiveness:\n","  e.append(i+5)\n","print(\"new list\",e)\n","\n","\n","print(\"\\nnormal method:\")\n","for i in effectiveness:\n","    print(i+5)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"DKMdG4tvgBWW","executionInfo":{"status":"ok","timestamp":1767244941310,"user_tz":-330,"elapse